# Reach uses Groq's OpenAI-compatible API for the AI siting rationale.
# This key is used ONLY server-side, inside the two API routes:
#   - app/api/ask/route.ts        (natural-language question -> category/district)
#   - app/api/recommend/route.ts  (streams the siting rationale)
#
# The app runs fully WITHOUT a key: it falls back to deterministic siting.
# When this key is set (copy this file to .env.local), the AI rationale streams live.
# GROQ_API_KEY=
